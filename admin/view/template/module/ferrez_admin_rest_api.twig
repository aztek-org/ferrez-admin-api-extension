{{ header }}
{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-ferrez-admin-rest-api" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fas fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fas fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="row mb-4">
      <div class="col-xl-3 col-md-6 mb-3">
        <div class="card h-100">
          <div class="card-header"><i class="fas fa-plug"></i> {{ text_status_card }}</div>
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="badge {{ status_badge_class }}">{{ status_text }}</span>
              <span class="text-muted">{{ module_ferrez_admin_rest_api_max_time_skew }}s</span>
            </div>
            <div class="small text-muted mb-1">{{ entry_max_time_skew }}</div>
            <div class="small text-muted">{{ text_allowed_origins }}: {{ allowed_origins_list ? allowed_origins_list|length : 0 }}</div>
            <div class="small text-muted">{{ text_extension_version }}: {{ extension_version }}</div>
            <div class="small text-muted">{{ text_capabilities_sync }}: {{ capabilities_synced_at }}</div>
          </div>
        </div>
      </div>
      <div class="col-xl-3 col-md-6 mb-3">
        <div class="card h-100">
          <div class="card-header"><i class="fas fa-user-shield"></i> {{ text_api_users_card }}</div>
          <div class="card-body">
            <div class="display-6 mb-2">{{ active_api_user_total }}/{{ api_user_total }}</div>
            <div class="small text-muted mb-3">{{ text_enabled }} / total</div>
            <a href="{{ api_user_list_link }}" class="btn btn-outline-primary btn-sm">{{ text_open_api_users }}</a>
          </div>
        </div>
      </div>
      <div class="col-xl-3 col-md-6 mb-3">
        <div class="card h-100">
          <div class="card-header"><i class="fas fa-key"></i> {{ text_scopes_card }}</div>
          <div class="card-body">
            <div class="display-6 mb-2">{{ scope_total }}</div>
            <div class="small text-muted">{{ scope_user_total }} {{ text_users_with_explicit_scope_maps }}</div>
          </div>
        </div>
      </div>
      <div class="col-xl-3 col-md-6 mb-3">
        <div class="card h-100">
          <div class="card-header"><i class="fas fa-diagram-project"></i> {{ text_endpoints_card }}</div>
          <div class="card-body">
            <div class="display-6 mb-2">{{ endpoint_total }}</div>
            <div class="small text-muted">{{ read_endpoint_total }} {{ text_read_endpoints }} / {{ write_endpoint_total }} {{ text_write_endpoints }}</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row mb-4">
      <div class="col-lg-5 mb-3">
        <div class="card h-100">
          <div class="card-header"><i class="fas fa-link"></i> {{ text_route_reference }}</div>
          <div class="card-body">
            <div class="mb-3">
              <div class="fw-bold mb-1">{{ text_extension_route }}</div>
              <code>{{ api_endpoint_base }}</code>
            </div>
            <div class="mb-3">
              <div class="fw-bold mb-1">{{ text_pretty_route }}</div>
              <code>{{ pretty_endpoint_base }}</code>
            </div>
            <div class="mb-0">
              <div class="fw-bold mb-1">{{ text_allowed_origins }}</div>
              {% if allowed_origins_list %}
                <ul class="mb-0 ps-3">
                  {% for origin in allowed_origins_list %}
                    <li><code>{{ origin }}</code></li>
                  {% endfor %}
                </ul>
              {% else %}
                <div class="text-muted">{{ text_no_origins }}</div>
              {% endif %}
            </div>
            <hr/>
            <div class="alert alert-info mb-0 py-2 px-3">
              <div class="fw-bold"><i class="fas fa-image"></i> {{ text_product_image_upload }}</div>
              <div class="small">{{ text_product_image_upload_hint }}</div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-7 mb-3">
        <div class="card h-100">
          <div class="card-header"><i class="fas fa-users"></i> {{ text_api_users }}</div>
          <div class="card-body p-0">
            {% if api_users %}
              <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                  <thead>
                    <tr>
                      <th>Username</th>
                      <th>Status</th>
                      <th>{{ text_ip_whitelist }}</th>
                      <th>{{ text_last_updated }}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for api_user in api_users %}
                      <tr>
                        <td><code>{{ api_user.username }}</code></td>
                        <td><span class="badge {{ api_user.status_badge_class }}">{{ api_user.status_text }}</span></td>
                        <td>{{ api_user.ip_total }}</td>
                        <td>{{ api_user.date_modified }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% else %}
              <div class="p-3 text-muted">{{ text_no_api_users }}</div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="row mb-4">
      <div class="col-lg-4 mb-3">
        <div class="card h-100">
          <div class="card-header"><i class="fas fa-user-lock"></i> {{ text_permission_overview }}</div>
          <div class="card-body">
            {% if scope_matrix %}
              {% for permission_row in scope_matrix %}
                <div class="border rounded p-3 mb-3">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong><code>{{ permission_row.username }}</code></strong>
                    <span class="badge bg-info text-dark">{{ permission_row.scope_total }} {{ text_scope_count }}</span>
                  </div>
                  <div>
                    {% for scope_name in permission_row.scopes %}
                      <span class="badge bg-light text-dark border mb-1">{{ scope_name }}</span>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            {% else %}
              <div class="text-muted">{{ text_no_permissions }}</div>
            {% endif %}
          </div>
        </div>
      </div>
      <div class="col-lg-8 mb-3">
        <div class="card h-100">
          <div class="card-header"><i class="fas fa-table-list"></i> {{ text_endpoint_catalog }}</div>
          <div class="card-body p-0">
            <div class="accordion accordion-flush" id="endpoint-accordion">
              {% for group in endpoint_groups %}
                <div class="accordion-item">
                  <h2 class="accordion-header" id="endpoint-heading-{{ loop.index }}">
                    <button class="accordion-button{% if not loop.first %} collapsed{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#endpoint-collapse-{{ loop.index }}" aria-expanded="{{ loop.first ? 'true' : 'false' }}" aria-controls="endpoint-collapse-{{ loop.index }}">
                      {{ group.title }}
                    </button>
                  </h2>
                  <div id="endpoint-collapse-{{ loop.index }}" class="accordion-collapse collapse{% if loop.first %} show{% endif %}" aria-labelledby="endpoint-heading-{{ loop.index }}" data-bs-parent="#endpoint-accordion">
                    <div class="accordion-body p-0">
                      <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                          <thead>
                            <tr>
                              <th>Call</th>
                              <th>{{ text_methods }}</th>
                              <th>{{ text_scope }}</th>
                              <th>{{ text_description }}</th>
                            </tr>
                          </thead>
                          <tbody>
                            {% for endpoint in group.endpoints %}
                              <tr>
                                <td><code>{{ endpoint.call }}</code></td>
                                <td>{{ endpoint.methods }}</td>
                                <td><code>{{ endpoint.scope }}</code></td>
                                <td>{{ endpoint.description }}</td>
                              </tr>
                            {% endfor %}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><i class="fas fa-pencil-alt"></i> {{ text_edit }}</div>
      <div class="card-body">
        <p class="text-muted">{{ text_configuration_help }}</p>
        <form id="form-ferrez-admin-rest-api" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <div class="row mb-3">
            <label class="col-sm-3 col-form-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-9">
              <div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="module_ferrez_admin_rest_api_status" value="0"/>
                <input type="checkbox" name="module_ferrez_admin_rest_api_status" value="1" id="input-status" class="form-check-input" {% if module_ferrez_admin_rest_api_status %}checked{% endif %}/>
              </div>
            </div>
          </div>

          <div class="row mb-3">
            <label class="col-sm-3 col-form-label" for="input-allowed-origins">{{ entry_allowed_origins }}</label>
            <div class="col-sm-9">
              <textarea name="module_ferrez_admin_rest_api_allowed_origins" rows="3" id="input-allowed-origins" class="form-control">{{ module_ferrez_admin_rest_api_allowed_origins }}</textarea>
              <div class="form-text">{{ help_allowed_origins }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label class="col-sm-3 col-form-label" for="input-max-time-skew">{{ entry_max_time_skew }}</label>
            <div class="col-sm-9">
              <input type="number" min="60" max="3600" name="module_ferrez_admin_rest_api_max_time_skew" value="{{ module_ferrez_admin_rest_api_max_time_skew }}" id="input-max-time-skew" class="form-control"/>
              <div id="error-max-time-skew" class="invalid-feedback"></div>
              <div class="form-text">{{ help_max_time_skew }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label class="col-sm-3 col-form-label" for="input-permissions">{{ entry_permissions }}</label>
            <div class="col-sm-9">
              <textarea name="module_ferrez_admin_rest_api_permissions" rows="8" id="input-permissions" class="form-control">{{ module_ferrez_admin_rest_api_permissions }}</textarea>
              <div id="error-permissions" class="invalid-feedback"></div>
              <div class="form-text">{{ help_permissions }}</div>
              <div class="mt-2"><span class="fw-bold">{{ text_permissions_example }}:</span> <code>{"Default":["admin.health.read","admin.orders.read"]}</code></div>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
